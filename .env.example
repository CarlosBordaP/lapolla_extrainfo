# Copy to .env and adjust for your environment. .env is gitignored.

# --- Database ---
# Production: set the MySQL connection below (leave DB_URL empty).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=polla
DB_PASSWORD=changeme
DB_NAME=polla
# Optional full SQLAlchemy URL override (wins over the fields above).
# Dev with SQLite:  DB_URL=sqlite:///./polla_dev.db
DB_URL=

# --- Access control ---
# Comma-separated Golpredictor usernames allowed in admin views (stats, audit, edits).
ADMIN_USERS=kliche

# --- OCR ingestion ---  engine: gemini (free) or claude
OCR_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Alternative engine (Anthropic, paid)
ANTHROPIC_API_KEY=
OCR_MODEL=claude-opus-4-8

# --- Live scores (365scores.com, no token needed) ---
SCORE_PROVIDER=scores365
SCORE_POLL_SECONDS=120
# Only used by the "worldcup_free" fallback provider:
SCORE_API_BASE_URL=https://worldcup26.ir
SCORE_API_TOKEN=
